---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQ from '../components/FAQ.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import { BUSINESS, SITE_CONFIG } from '../config/business';

const canonical = `${SITE_CONFIG.url}/indoor-air-quality-chicago/`;
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Indoor Air Quality', path: '/indoor-air-quality-chicago/' },
];

const faqItems = [
  { question: 'How can I improve the air quality in my Chicago home?', answer: 'Start with simple steps like changing your air filter regularly and ensuring proper ventilation. For more comprehensive solutions, consider air purification systems, UV air sanitizers, whole-home humidifiers, and regular duct cleaning.' },
  { question: 'What is the best air purification system for my home?', answer: 'The best system depends on your specific needs. We offer a range of solutions including whole-home air cleaners, HEPA filtration systems, and UV air sanitizers. We\'ll assess your home and recommend the right solution.' },
  { question: 'How often should I have my air ducts cleaned?', answer: 'Most homes benefit from air duct cleaning every 3-5 years. However, if you have pets, smokers, recent renovations, or allergy sufferers in your home, more frequent cleaning may be beneficial.' },
  { question: 'Can indoor air quality affect my health?', answer: 'Yes, poor indoor air quality can contribute to allergies, asthma symptoms, headaches, fatigue, and respiratory issues. Improving your IAQ can make a significant difference in your family\'s comfort and health.' },
];
---

<BaseLayout title={`Indoor Air Quality in Chicago, IL | Air Purification | ${BUSINESS.name}`} description={`Improve indoor air quality in your Chicago home with air purification, filtration, duct cleaning, and IAQ solutions from ${BUSINESS.name}. Call ${BUSINESS.phone}.`} canonical={canonical} breadcrumbs={breadcrumbs}>
  <LocalBusinessSchema page="service" serviceName="Indoor Air Quality" serviceDescription="Indoor air quality solutions including air purification, filtration, duct cleaning, and ventilation for Chicago homes." />
  <Header currentPath="/indoor-air-quality-chicago/" breadcrumbs={breadcrumbs} />

  <main>
    <Hero headline="Indoor Air Quality Solutions in Chicago" subheadline="Breathe cleaner, healthier air. We offer air purification, filtration, ventilation, and duct cleaning services for Chicago homes." backgroundImage="/images/chicago-heating-air/thermostats-hvacbackground-0.jpg" variant="interior" />

    <section class="section">
      <div class="container">
        <div class="content-grid">
          <div>
            <span class="section-tag">Service Detail</span>
            <h2>Breathe Cleaner Air at Home</h2>
            <p>The air inside your home can contain dust, pollen, pet dander, mold spores, and other pollutants that affect your comfort and health. At {BUSINESS.name}, we offer a full range of indoor air quality solutions designed to remove contaminants and improve ventilation.</p>
            <p>Whether you need a simple air filter upgrade, a whole-home purification system, or professional duct cleaning, our team will help you find the right solution for your home and budget.</p>
            <h3 style="margin-top:2rem;font-size:1.25rem;">Our IAQ Services</h3>
            <ul class="check-list">
              <li>Whole-home air purification systems</li>
              <li>HEPA and media filtration</li>
              <li>UV air sanitizers and germicidal lights</li>
              <li>Air duct cleaning and sanitization</li>
              <li>Ventilation system improvements</li>
              <li>Humidifier and dehumidifier installation</li>
              <li>Carbon monoxide monitoring</li>
              <li>Energy recovery ventilators (ERVs)</li>
              <li>Zoning systems for targeted comfort</li>
            </ul>
          </div>
          <div class="content-sidebar">
            <div class="sidebar-cta">
              <h3>Improve Your Home's Air Quality</h3>
              <p>Call us to discuss indoor air quality solutions for your Chicago home.</p>
              <a href={`tel:${BUSINESS.phoneRaw}`} class="btn btn-primary" style="width:100%;justify-content:center;padding:1rem;">{BUSINESS.phone}</a>
              <a href="/contact/" class="btn btn-outline" style="width:100%;justify-content:center;margin-top:0.75rem;">Request Service</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background:#f8fafc;">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Signs to Watch For</span>
          <h2>Signs You May Need IAQ Solutions</h2>
          <p class="section-desc">If you're experiencing any of these, your home's air quality could use improvement.</p>
        </div>
        <div class="iaq-signs-grid">
          <div class="iaq-sign"><span class="iaq-sign-icon" aria-hidden="true">😷</span><h3>Allergy Symptoms</h3><p>Sneezing, watery eyes, and congestion that improve when you leave home.</p></div>
          <div class="iaq-sign"><span class="iaq-sign-icon" aria-hidden="true">💨</span><h3>Excess Dust</h3><p>Dust accumulates quickly on surfaces even after cleaning.</p></div>
          <div class="iaq-sign"><span class="iaq-sign-icon" aria-hidden="true">👃</span><h3>Musty Odors</h3><p>Persistent smells that suggest mold, mildew, or poor ventilation.</p></div>
          <div class="iaq-sign"><span class="iaq-sign-icon" aria-hidden="true">💧</span><h3>Excess Humidity</h3><p>Sticky air, condensation on windows, or mold growth in bathrooms.</p></div>
          <div class="iaq-sign"><span class="iaq-sign-icon" aria-hidden="true">🫁</span><h3>Respiratory Issues</h3><p>Asthma flare-ups or breathing difficulties that worsen indoors.</p></div>
          <div class="iaq-sign"><span class="iaq-sign-icon" aria-hidden="true">🌡️</span><h3>Stale Air</h3><p>Rooms feel stuffy or uncomfortable despite proper heating and cooling.</p></div>
        </div>
      </div>
    </section>

    <FAQ items={faqItems} title="Indoor Air Quality Questions" subtitle="Common questions about improving air quality in Chicago homes." />
    <ContactForm title="Request IAQ Consultation" subtitle="Tell us about your air quality concerns and we'll recommend the right solution." />
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  .iaq-signs-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; max-width: 800px; margin: 0 auto; }
  @media (min-width: 640px) { .iaq-signs-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .iaq-signs-grid { grid-template-columns: repeat(3, 1fr); } }
  .iaq-sign { text-align: center; padding: 2rem 1.5rem; background: #fff; border: 1px solid #e2e8f0; border-radius: 0.75rem; transition: box-shadow 0.2s; }
  .iaq-sign:hover { box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06); }
  .iaq-sign-icon { font-size: 2.5rem; display: block; margin-bottom: 0.75rem; }
  .iaq-sign h3 { font-size: 1rem; margin-bottom: 0.5rem; }
  .iaq-sign p { color: #64748b; font-size: 0.875rem; line-height: 1.6; }
</style>
