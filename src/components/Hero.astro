---
import { BUSINESS } from '../config/business';

interface Props {
  headline: string;
  subheadline?: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
  backgroundImage?: string;
  variant?: 'home' | 'interior';
  showRating?: boolean;
  showBookingForm?: boolean;
}

const {
  headline,
  subheadline,
  primaryCta = { text: `Call ${BUSINESS.phone}`, href: `tel:${BUSINESS.phoneRaw}` },
  secondaryCta = { text: 'Request Service', href: '/contact/' },
  backgroundImage = '/images/chicago-heating-air/HeaderHVACInstallation-AC-Repair-0.jpg',
  variant = 'home',
  showRating = false,
  showBookingForm = false,
} = Astro.props;
---

<section class={`hero hero--${variant}`} aria-label="Hero banner">
  <div class="hero-bg" aria-hidden="true">
    <img
      src={backgroundImage}
      alt=""
      loading="eager"
      decoding="async"
      width="1920"
      height="1080"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content container">
    {variant === 'home' ? (
      <div class="hero-split">
        <!-- Left: Content -->
        <div class="hero-split-left">
          <h1 class="hero-headline">{headline}</h1>
          {subheadline && <p class="hero-subheadline">{subheadline}</p>}

          <div class="hero-actions">
            <a href={primaryCta.href} class="btn btn-primary btn-hero">{primaryCta.text}</a>
            <a href={secondaryCta.href} class="btn btn-white btn-hero">{secondaryCta.text}</a>
          </div>

          <div class="hero-metrics">
            {showRating && (
              <span class="hero-rating">
                <span class="hero-stars" aria-hidden="true">
                  {Array.from({ length: 5 }, (_, i) => (
                    <svg key={i} width="18" height="18" viewBox="0 0 24 24" fill={i < Math.floor(BUSINESS.googleRating) ? '#fbbf24' : '#475569'} aria-hidden="true">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  ))}
                </span>
                <span class="hero-rating-text">
                  <strong>{BUSINESS.googleRating}</strong> — {BUSINESS.googleReviewCount} Google reviews
                </span>
              </span>
            )}
            <span class="hero-metric">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Licensed, Bonded &amp; Insured
            </span>
          </div>
        </div>

        <!-- Right: Booking Form Card -->
        <div class="hero-split-right">
          {showBookingForm && (
            <div class="hero-booking-card">
              <div class="hero-booking-header">
                <h3 class="hero-booking-title">Book a Service Visit</h3>
                <p class="hero-booking-sub">We'll confirm your appointment promptly</p>
              </div>
              <form class="hero-booking-form" id="heroQuickForm" method="POST" action="/contact/">
                <div class="hero-booking-field">
                  <label for="heroName" class="sr-only">Full Name</label>
                  <input type="text" id="heroName" name="name" required placeholder="Your full name" class="hero-booking-input" />
                </div>
                <div class="hero-booking-field">
                  <label for="heroPhone" class="sr-only">Phone Number</label>
                  <input type="tel" id="heroPhone" name="phone" required placeholder="Phone number" class="hero-booking-input" />
                </div>
                <div class="hero-booking-field">
                  <label for="heroService" class="sr-only">Service Needed</label>
                  <select id="heroService" name="service" required class="hero-booking-input">
                    <option value="">What do you need?</option>
                    <option value="AC Repair">AC Repair</option>
                    <option value="Furnace Repair">Furnace Repair</option>
                    <option value="AC Installation">AC Installation</option>
                    <option value="Emergency HVAC">Emergency HVAC</option>
                    <option value="Maintenance">Maintenance</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
                <div class="hero-booking-field">
                  <label for="heroEmail" class="sr-only">Email</label>
                  <input type="email" id="heroEmail" name="email" placeholder="Email (optional)" class="hero-booking-input" />
                </div>
                <button type="submit" class="hero-booking-btn">Request Service</button>
                <p class="hero-booking-disclaimer">Or call <a href={`tel:${BUSINESS.phoneRaw}`}>{BUSINESS.phone}</a> for immediate help</p>
                <p class="hero-booking-privacy">Your information is kept private and secure</p>
              </form>
            </div>
          )}
        </div>
      </div>
    ) : (
      /* Interior variant: centered, compact */
      <div class="hero-interior-content">
        <h1 class="hero-headline">{headline}</h1>
        {subheadline && <p class="hero-subheadline">{subheadline}</p>}
        <div class="hero-actions hero-actions--centered">
          <a href={primaryCta.href} class="btn btn-primary btn-hero">{primaryCta.text}</a>
          <a href={secondaryCta.href} class="btn btn-white btn-hero">{secondaryCta.text}</a>
        </div>
      </div>
    )}
  </div>
</section>

<script>
  const quickForm = document.getElementById('heroQuickForm');
  if (quickForm) {
    quickForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = quickForm.querySelector('.hero-booking-btn');
      if (btn) { btn.textContent = 'Sending...'; btn.disabled = true; }
      setTimeout(() => {
        const successMsg = document.createElement('div');
        successMsg.style.cssText = 'text-align:center;padding:1rem;color:#16a34a;font-weight:600;';
        successMsg.textContent = 'Thank you! We\'ll contact you shortly.';
        quickForm.replaceWith(successMsg);
      }, 1200);
    });
  }
</script>

<style is:global>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 92vh;
    overflow: hidden;
  }

  .hero--interior {
    min-height: 38vh;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(15, 23, 42, 0.94) 0%,
      rgba(15, 23, 42, 0.65) 50%,
      rgba(15, 23, 42, 0.4) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  /* === HOME SPLIT LAYOUT === */
  .hero-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-split {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .hero-split-left {
    max-width: 680px;
  }

  .hero-headline {
    color: #fff;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }

  .hero-subheadline {
    color: #cbd5e1;
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 600px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .hero-actions--centered {
    justify-content: center;
  }

  .btn-hero {
    padding: 1rem 2rem;
    font-size: 1.125rem;
    min-height: 56px;
  }

  .hero-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    align-items: center;
  }

  .hero-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(6px);
    padding: 0.5rem 1rem;
    border-radius: 9999px;
  }

  .hero-stars { display: flex; gap: 1px; }

  .hero-rating-text {
    color: #e2e8f0;
    font-size: 0.8125rem;
    white-space: nowrap;
  }

  .hero-rating-text strong { color: #fbbf24; }

  .hero-metric {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: #94a3b8;
    font-size: 0.8125rem;
  }

  /* === BOOKING FORM CARD === */
  .hero-booking-card {
    background: #fff;
    border-radius: 1rem;
    padding: 2rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
    max-width: 400px;
    margin: 0 auto;
    width: 100%;
  }

  .hero-booking-header {
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .hero-booking-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.25rem;
  }

  .hero-booking-sub {
    font-size: 0.85rem;
    color: #64748b;
  }

  .hero-booking-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero-booking-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-family: inherit;
    color: #1a1a2e;
    background: #f8fafc;
    border: 1.5px solid #e2e8f0;
    border-radius: 0.5rem;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    min-height: 48px;
  }

  .hero-booking-input:focus {
    outline: none;
    border-color: #f97316;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.12);
  }

  .hero-booking-btn {
    width: 100%;
    padding: 0.875rem;
    font-size: 1rem;
    font-weight: 700;
    font-family: inherit;
    color: #fff;
    background: #f97316;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    min-height: 48px;
  }

  .hero-booking-btn:hover {
    background: #ea580c;
    transform: translateY(-1px);
  }

  .hero-booking-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .hero-booking-disclaimer {
    text-align: center;
    font-size: 0.8rem;
    color: #94a3b8;
    margin-top: 0.25rem;
  }

  .hero-booking-disclaimer a {
    color: #f97316;
    font-weight: 600;
  }

  .hero-booking-disclaimer a:hover {
    text-decoration: underline;
  }

  .hero-booking-privacy {
    text-align: center;
    font-size: 0.7rem;
    color: #94a3b8;
  }

  /* === INTERIOR === */
  .hero--interior .hero-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .hero--interior .hero-headline {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    margin-bottom: 0.875rem;
  }

  .hero--interior .hero-subheadline {
    margin: 0 auto 1.5rem;
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
  }

  @media (max-width: 767px) {
    .hero { min-height: 80vh; }
    .hero--interior { min-height: 35vh; }
    .hero--interior .hero-content { padding: 2rem 0; }
    .hero-actions { flex-direction: column; }
    .btn-hero { width: 100%; justify-content: center; }
    .hero-metrics { flex-direction: column; align-items: flex-start; }
    .hero-booking-card { max-width: 100%; }
  }
</style>
