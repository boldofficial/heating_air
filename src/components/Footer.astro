---
import { BUSINESS } from '../config/business';
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <h3 class="footer-heading">{BUSINESS.name}</h3>
        <p class="footer-text">
          Professional heating, cooling, and indoor air quality services for Chicago homes and businesses. Family-owned, locally trusted.
        </p>
        <div class="footer-rating">
          <span class="stars" aria-label={`${BUSINESS.googleRating} star rating`}>
            {Array.from({ length: 5 }, (_, i) => (
              <svg key={i} width="18" height="18" viewBox="0 0 24 24" fill={i < Math.floor(BUSINESS.googleRating) ? '#f97316' : '#e2e8f0'} aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </span>
          <span class="rating-text">{BUSINESS.googleRating} Google Rating ({BUSINESS.googleReviewCount} reviews)</span>
        </div>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Services</h3>
        <ul class="footer-links">
          <li><a href="/ac-repair-chicago/">AC Repair</a></li>
          <li><a href="/furnace-repair-chicago/">Furnace Repair</a></li>
          <li><a href="/ac-installation-chicago/">AC Installation</a></li>
          <li><a href="/emergency-hvac-service-chicago/">Emergency HVAC</a></li>
          <li><a href="/indoor-air-quality-chicago/">Indoor Air Quality</a></li>
          <li><a href="/hvac-maintenance-chicago/">Maintenance</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Contact</h3>
        <address class="footer-address">
          <div class="footer-contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>{BUSINESS.address.full}</span>
          </div>
          <div class="footer-contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href={`tel:${BUSINESS.phoneRaw}`}>{BUSINESS.phone}</a>
          </div>
          <div class="footer-contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a>
          </div>
        </address>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Hours</h3>
        <ul class="footer-hours">
          <li><span>Mon–Fri</span><span>{BUSINESS.hours.weekday}</span></li>
          <li><span>Saturday</span><span>{BUSINESS.hours.saturday}</span></li>
          <li><span>Sunday</span><span>{BUSINESS.hours.sunday}</span></li>
          <li class="footer-emergency">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" aria-hidden="true">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <span>Emergency service available — call for assistance</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {BUSINESS.name}. All rights reserved. Licensed, Bonded &amp; Insured.</p>
      <nav class="footer-bottom-links" aria-label="Footer legal links">
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/contact/">Contact</a>
        <a href="/service-area/chicago/">Service Area</a>
      </nav>
      <p class="footer-credit">Developed by <a href="https://getboldideas.com" target="_blank" rel="noopener noreferrer">BOLD IDEAS</a></p>
    </div>
  </div>
</footer>

<style is:global>
  .site-footer {
    background: #0f172a;
    color: #cbd5e1;
    padding: 4rem 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 640px) { .footer-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .footer-grid { grid-template-columns: 1.5fr 1fr 1.25fr 1fr; } }

  .footer-heading {
    font-size: 1.125rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
  }

  .footer-text {
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .footer-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .stars { display: flex; gap: 1px; }

  .rating-text {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a {
    color: #cbd5e1;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: #f97316; }

  .footer-address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9rem;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .footer-contact-item a { color: #cbd5e1; transition: color 0.2s; }
  .footer-contact-item a:hover { color: #f97316; }

  .footer-hours {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.9rem;
  }

  .footer-hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-emergency {
    display: flex !important;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid #1e293b;
    font-size: 0.825rem;
    color: #f97316;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem 0;
    margin-top: 3rem;
    border-top: 1px solid #1e293b;
    font-size: 0.825rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-bottom-links { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem 1.5rem; }

  .footer-bottom-links a {
    color: #94a3b8;
    transition: color 0.2s;
  }

  .footer-bottom-links a:hover { color: #f97316; }

  .footer-credit {
    font-size: 0.8rem;
    color: #64748b;
  }

  .footer-credit a {
    color: #f97316;
    font-weight: 600;
    transition: color 0.2s;
  }

  .footer-credit a:hover {
    color: #fb923c;
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .site-footer {
      padding-top: 3rem;
    }

    .footer-grid {
      gap: 2rem;
    }

    .footer-hours li {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.125rem;
    }

    .footer-emergency {
      flex-direction: row;
    }
  }
</style>
